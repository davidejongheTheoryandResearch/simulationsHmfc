library(readr)
library(dplyr)
df <- read_csv("/Users/daviddejonghe/Documents/Psychologie/Masterproef/simulationsHmfc/hmfc_with_symptoms.csv")
#make log_sigmasq
df <- df %>%
mutate(
log_sigmasq = log(sigmasq)
)
#Standardize predictors
df_reg <- df %>%
mutate(
Age_z = as.numeric(scale(Age)),
AnxiousDepression_z = as.numeric(scale(AnxiousDepression)),
Compulsivity_z = as.numeric(scale(Compulsivity)),
SocialWithdrawal_z = as.numeric(scale(SocialWithdrawal))
)
#single regressions
m_a_AD <- lm(a ~ AnxiousDepression_z + Age_z + Sex, data = df_reg)
m_a_CIT <- lm(a ~ Compulsivity_z + Age_z + Sex, data = df_reg)
m_a_SW <- lm(a ~ SocialWithdrawal_z + Age_z + Sex, data = df_reg)
m_s_AD <- lm(log_sigmasq ~ AnxiousDepression_z + Age_z + Sex, data = df_reg)
m_s_CIT <- lm(log_sigmasq ~ Compulsivity_z + Age_z + Sex, data = df_reg)
m_s_SW <- lm(log_sigmasq ~ SocialWithdrawal_z + Age_z + Sex, data = df_reg)
#Summaries
summary(m_a_AD)
summary(m_a_CIT)
summary(m_a_SW)
summary(m_s_AD)
summary(m_s_CIT)
summary(m_s_SW)
#Combined regression
m_a_combined <- lm(
a ~ AnxiousDepression_z + Compulsivity_z + SocialWithdrawal_z + Age_z + Sex,
data = df_reg
)
m_s_combined <- lm(
log_sigmasq ~ AnxiousDepression_z + Compulsivity_z + SocialWithdrawal_z + Age_z + Sex,
data = df_reg
)
#Summaries
summary(m_a_combined)
summary(m_s_combined)
library(broom)
tidy(m_a_combined, conf.int = TRUE)
tidy(m_s_combined, conf.int = TRUE)
library(readr)
library(dplyr)
library(broom)
library(purrr)
library(ggplot2)
# Single regression (visual)
single_models <- list(
"AD_a" = m_a_AD,
"CIT_a" = m_a_CIT,
"SW_a" = m_a_SW,
"AD_logsigmasq" = m_s_AD,
"CIT_logsigmasq" = m_s_CIT,
"SW_logsigmasq" = m_s_SW
)
single_plot_df <- bind_rows(
tidy(m_a_AD, conf.int = TRUE) %>% mutate(model = "AD_a"),
tidy(m_a_CIT, conf.int = TRUE) %>% mutate(model = "CIT_a"),
tidy(m_a_SW, conf.int = TRUE) %>% mutate(model = "SW_a"),
tidy(m_s_AD, conf.int = TRUE) %>% mutate(model = "AD_logsigmasq"),
tidy(m_s_CIT, conf.int = TRUE) %>% mutate(model = "CIT_logsigmasq"),
tidy(m_s_SW, conf.int = TRUE) %>% mutate(model = "SW_logsigmasq")
)
single_plot_df
View(single_plot_df)
View(single_models)
single_plot_df
single_plot_df <- single_plot_df %>%
filter(
(model == "AD_a" & term == "AnxiousDepression_z") |
(model == "CIT_a" & term == "Compulsivity_z") |
(model == "SW_a" & term == "SocialWithdrawal_z") |
(model == "AD_logsigmasq" & term == "AnxiousDepression_z") |
(model == "CIT_logsigmasq" & term == "Compulsivity_z") |
(model == "SW_logsigmasq" & term == "SocialWithdrawal_z")
) %>%
mutate(
predictor = case_when(
term == "AnxiousDepression_z" ~ "AD",
term == "Compulsivity_z" ~ "CIT",
term == "SocialWithdrawal_z" ~ "SW"
),
outcome = case_when(
grepl("_a$", model) ~ "a",
grepl("logsigmasq$", model) ~ "log σ²"
)
)
ggplot(single_plot_df, aes(x = predictor, y = estimate, fill = outcome)) +
geom_col(position = position_dodge(width = 0.7), width = 0.6) +
geom_errorbar(
aes(ymin = conf.low, ymax = conf.high),
position = position_dodge(width = 0.7),
width = 0.2
) +
geom_hline(yintercept = 0, linewidth = 0.5) +
labs(
title = "Single-predictor regression models",
x = "Predictor",
y = "Regression coefficient",
fill = "Outcome"
) +
theme_minimal(base_size = 12)
#Combined regression (visual)
combined_plot_df <- bind_rows(
tidy(m_a_combined, conf.int = TRUE) %>% mutate(outcome = "a"),
tidy(m_s_combined, conf.int = TRUE) %>% mutate(outcome = "log σ²")
) %>%
filter(term %in% c("AnxiousDepression_z", "Compulsivity_z", "SocialWithdrawal_z")) %>%
mutate(
predictor = case_when(
term == "AnxiousDepression_z" ~ "AD",
term == "Compulsivity_z" ~ "CIT",
term == "SocialWithdrawal_z" ~ "SW"
)
)
combined_plot_df
ggplot(combined_plot_df, aes(x = outcome, y = estimate, fill = predictor)) +
geom_col(position = position_dodge(width = 0.7), width = 0.6) +
geom_errorbar(
aes(ymin = conf.low, ymax = conf.high),
position = position_dodge(width = 0.7),
width = 0.2
) +
geom_hline(yintercept = 0, linewidth = 0.5) +
labs(
title = "Combined regression model",
x = NULL,
y = "Regression coefficient",
fill = "Predictor"
) +
theme_minimal(base_size = 12)
